              <button data-motion="button" type="button" class="px-8 py-3.5 bg-orange-600 hover:bg-orange-700 rounded-xl text-white font-semibold transition-colors whitespace-nowrap">
                Get Free Access
              </button>
            </div>

            <!-- Social Proof -->
            <div class="flex items-center gap-4 lg:pl-6 lg: border-neutral-200 dark:border-neutral-700" data-motion="social-proof">
              <div class="flex -space-x-2">
                <img data-motion="avatar" src="https://images.unsplash.com/photo-1494790108377-be9c29b29330?w=100&auto=format&fit=crop&q=80" alt="Student" class="w-8 h-8 rounded-full border-2 border-white dark:border-neutral-900 object-cover">
                <img data-motion="avatar" src="https://images.unsplash.com/photo-1507003211169-0a1dd7228f2d?w=100&auto=format&fit=crop&q=80" alt="Student" class="w-8 h-8 rounded-full border-2 border-white dark:border-neutral-900 object-cover">
                <img data-motion="avatar" src="https://images.unsplash.com/photo-1438761681033-6461ffad8d80?w=100&auto=format&fit=crop&q=80" alt="Student" class="w-8 h-8 rounded-full border-2 border-white dark:border-neutral-900 object-cover">
