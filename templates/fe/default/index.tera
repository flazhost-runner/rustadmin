{% extends "layouts/fe/default/main" %}
{% block content %}
<section id="_hero_digital_agency_v6_001" class="py-20 sm:py-24 bg-white dark:bg-neutral-950">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <!-- Stacked Layout -->
    <div class="flex flex-col gap-12">
      <!-- Full-width Image -->
      <div class="w-full h-72 sm:h-96 rounded-3xl overflow-hidden relative" data-motion="image">
        <img data-motion="image"
          src="https://images.unsplash.com/photo-1522071820081-009f0129c71c?w=1400&auto=format&fit=crop&q=80"
          alt="Digital agency team collaboration"
          class="w-full h-full object-cover"
        >
        <!-- Floating Badge -->
        <div data-motion="card" class="absolute top-6 left-6 px-4 py-2 bg-white/90 dark:bg-neutral-900/90 backdrop-blur-xs rounded-full">
          <span data-motion="badge" class="text-orange-600 dark:text-orange-400 text-sm font-semibold">Since 2012</span>
        </div>
      </div>

      <!-- Content Grid -->
      <div class="grid lg:grid-cols-5 gap-10">
        <!-- Main Content - 3 columns -->
        <div class="lg:col-span-3" data-motion="hero">
          <!-- Hero — bind ke landing (badge=AppName, heading=AppName, deskripsi). -->
          <span data-motion="badge" class="text-orange-600 dark:text-orange-400 text-sm font-semibold tracking-wide uppercase mb-4 block">{{ landing.app_name }}</span>
          <h1 class="text-4xl sm:text-5xl lg:text-6xl font-bold text-neutral-900 dark:text-white leading-tight mb-6">
            <span data-animate="heading">Welcome to</span><br>
            <span data-animate="heading" class="text-orange-600 dark:text-orange-400">{{ landing.app_name }}</span>
          </h1>
          <p class="text-lg text-neutral-600 dark:text-neutral-400 mb-8" data-animate="text">
            {% if landing.description %}{{ landing.description | safe }}{% else %}Partner with us to transform your vision into exceptional digital experiences. From strategy to execution, we deliver solutions that drive growth and innovation.{% endif %}
          </p>
          <div class="flex flex-wrap gap-4">
            <a href="/auth/login" data-motion="button" class="px-6 py-3 bg-orange-600 hover:bg-orange-700 transition-colors rounded-full text-white font-semibold">
              Start Your Project
            </a>
            <a href="#" data-motion="button" class="inline-flex items-center gap-2 text-orange-600 dark:text-orange-400 font-semibold hover:gap-3 transition-all duration-300">
              View Case Studies
              <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3"/>
              </svg>
            </a>
          </div>
        </div>

        <!-- Stats - 2 columns -->
        <div class="lg:col-span-2 flex flex-col gap-6">
          <div data-motion="card" class="p-6 bg-orange-50 dark:bg-orange-950/30 rounded-2xl">
            <span class="text-4xl font-bold text-orange-600 dark:text-orange-400 block mb-1">150+</span>
            <span class="text-neutral-600 dark:text-neutral-400">Projects delivered for clients worldwide</span>
          </div>
          <div class="grid grid-cols-2 gap-4">
            <div data-motion="card" class="p-5 bg-neutral-50 dark:bg-neutral-900 rounded-2xl">
              <span class="text-2xl font-bold text-neutral-900 dark:text-white block">12</span>
              <span class="text-neutral-500 dark:text-neutral-400 text-sm">Years</span>
            </div>
            <div data-motion="card" class="p-5 bg-neutral-50 dark:bg-neutral-900 rounded-2xl">
              <span class="text-2xl font-bold text-neutral-900 dark:text-white block">98%</span>
              <span class="text-neutral-500 dark:text-neutral-400 text-sm">Satisfaction</span>
            </div>
          </div>
          <div data-motion="card" class="p-5 bg-neutral-50 dark:bg-neutral-900 rounded-2xl">
            <div class="flex items-center gap-3">
              <div class="flex -space-x-2">
                <img data-motion="avatar" src="https://images.unsplash.com/photo-1494790108377-be9c29b29330?w=100&auto=format&fit=crop&q=80" alt="Team member" class="w-8 h-8 rounded-full border-2 border-white dark:border-neutral-900 object-cover">
                <img data-motion="avatar" src="https://images.unsplash.com/photo-1507003211169-0a1dd7228f2d?w=100&auto=format&fit=crop&q=80" alt="Team member" class="w-8 h-8 rounded-full border-2 border-white dark:border-neutral-900 object-cover">
                <img data-motion="avatar" src="https://images.unsplash.com/photo-1438761681033-6461ffad8d80?w=100&auto=format&fit=crop&q=80" alt="Team member" class="w-8 h-8 rounded-full border-2 border-white dark:border-neutral-900 object-cover">
              </div>
              <span class="text-neutral-600 dark:text-neutral-400 text-sm">35+ team members</span>
            </div>
          </div>
        </div>
      </div>

      <!-- Services Row -->
      <div class="grid grid-cols-2 lg:grid-cols-4 gap-4 pt-8 border-t border-neutral-200 dark:border-neutral-800" data-motion="social-proof">
        <div class="flex items-center gap-2 text-neutral-600 dark:text-neutral-400">
          <svg class="w-5 h-5 text-orange-600 dark:text-orange-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9.75 17L9 20l-1 1h8l-1-1-.75-3M3 13h18M5 17h14a2 2 0 002-2V5a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"/>
          </svg>
          <span class="text-sm font-medium">Web Development</span>
        </div>
        <div class="flex items-center gap-2 text-neutral-600 dark:text-neutral-400">
          <svg class="w-5 h-5 text-orange-600 dark:text-orange-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M7 21a4 4 0 01-4-4V5a2 2 0 012-2h4a2 2 0 012 2v12a4 4 0 01-4 4zm0 0h12a2 2 0 002-2v-4a2 2 0 00-2-2h-2.343M11 7.343l1.657-1.657a2 2 0 012.828 0l2.829 2.829a2 2 0 010 2.828l-8.486 8.485M7 17h.01"/>
          </svg>
          <span class="text-sm font-medium">Brand Design</span>
        </div>
        <div class="flex items-center gap-2 text-neutral-600 dark:text-neutral-400">
          <svg class="w-5 h-5 text-orange-600 dark:text-orange-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M11 3.055A9.001 9.001 0 1020.945 13H11V3.055z"/>
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M20.488 9H15V3.512A9.025 9.025 0 0120.488 9z"/>
          </svg>
          <span class="text-sm font-medium">Digital Marketing</span>
        </div>
        <div class="flex items-center gap-2 text-neutral-600 dark:text-neutral-400">
          <svg class="w-5 h-5 text-orange-600 dark:text-orange-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 18h.01M8 21h8a2 2 0 002-2V5a2 2 0 00-2-2H8a2 2 0 00-2 2v14a2 2 0 002 2z"/>
          </svg>
          <span class="text-sm font-medium">Mobile Apps</span>
        </div>
      </div>
    </div>
  </div>
</section>
<section id="_clients_simple_header_v6_001" class="py-20 sm:py-24 bg-orange-50 dark:bg-orange-950/20">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">

    <!-- Centered Header -->
    <div class="text-center mb-12">
      <p class="text-neutral-600 dark:text-neutral-400 text-lg" data-animate="text">Trusted by industry leaders</p>
    </div>

    <!-- Logo Row -->
    <div class="flex flex-wrap justify-center items-center gap-x-12 gap-y-8">
      <a data-motion="logo" href="#" class="text-neutral-400 dark:text-neutral-500 hover:text-orange-600 dark:hover:text-orange-400 transition-colors">
        <img src="https://raw.githubusercontent.com/gilbarbara/logos/main/logos/vmware.svg" alt="VMware" class="h-6 w-auto grayscale hover:grayscale-0 transition-all duration-300" />
      </a>
      <a data-motion="logo" href="#" class="text-neutral-400 dark:text-neutral-500 hover:text-orange-600 dark:hover:text-orange-400 transition-colors">
        <img src="https://raw.githubusercontent.com/gilbarbara/logos/main/logos/amd.svg" alt="AMD" class="h-6 w-auto grayscale hover:grayscale-0 transition-all duration-300" />
      </a>
      <a data-motion="logo" href="#" class="text-neutral-400 dark:text-neutral-500 hover:text-orange-600 dark:hover:text-orange-400 transition-colors">
        <img src="https://raw.githubusercontent.com/gilbarbara/logos/main/logos/qualcomm.svg" alt="Qualcomm" class="h-6 w-auto grayscale hover:grayscale-0 transition-all duration-300" />
      </a>
      <a data-motion="logo" href="#" class="text-neutral-400 dark:text-neutral-500 hover:text-orange-600 dark:hover:text-orange-400 transition-colors">
        <img src="https://raw.githubusercontent.com/gilbarbara/logos/main/logos/nvidia.svg" alt="Nvidia" class="h-6 w-auto grayscale hover:grayscale-0 transition-all duration-300" />
      </a>
      <a data-motion="logo" href="#" class="text-neutral-400 dark:text-neutral-500 hover:text-orange-600 dark:hover:text-orange-400 transition-colors">
        <img src="https://raw.githubusercontent.com/gilbarbara/logos/main/logos/paypal.svg" alt="PayPal" class="h-6 w-auto grayscale hover:grayscale-0 transition-all duration-300" />
      </a>
    </div>
  </div>
</section>
<section id="_features_colorful_cards_v6_001" class="py-20 sm:py-24 bg-white dark:bg-neutral-950">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <!-- Magazine Layout -->
    <div class="flex flex-col gap-16">
      <!-- Header Row -->
      <div class="grid lg:grid-cols-2 gap-12 items-end">
        <div data-motion="hero">
          <span data-motion="badge" class="text-orange-600 dark:text-orange-400 text-sm font-semibold tracking-wide uppercase mb-4 block">Workspace Tools</span>
          <h2>
            <span data-animate="heading" class="text-4xl sm:text-5xl lg:text-6xl font-bold text-neutral-900 dark:text-white leading-tight">Built for Modern Teams</span>
          </h2>
        </div>
        <div data-motion="card" class="lg:text-right">
          <p data-animate="text" class="text-lg text-neutral-600 dark:text-neutral-400 mb-6">
            Streamline your daily workflow with intelligent tools designed to boost productivity and keep your team aligned.
          </p>
          <a data-motion="button" href="#" class="inline-flex items-center gap-2 px-6 py-3 bg-orange-600 hover:bg-orange-700 text-white font-semibold rounded-full transition-colors">
            Get Started Free
            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3"/>
            </svg>
          </a>
        </div>
      </div>

      <!-- Feature Cards - Asymmetric Grid -->
      <div class="grid lg:grid-cols-12 gap-6">
        <!-- Large Card -->
        <div data-motion="card" class="lg:col-span-5 p-8 bg-orange-50 dark:bg-orange-900/20 rounded-3xl flex flex-col gap-6">
          <div data-motion="icon" class="w-14 h-14 bg-white dark:bg-neutral-800 rounded-2xl flex items-center justify-center">
            <svg class="w-7 h-7 text-orange-600 dark:text-orange-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M9 12h3.75M9 15h3.75M9 18h3.75m3 .75H18a2.25 2.25 0 0 0 2.25-2.25V6.108c0-1.135-.845-2.098-1.976-2.192a48.424 48.424 0 0 0-1.123-.08m-5.801 0c-.065.21-.1.433-.1.664 0 .414.336.75.75.75h4.5a.75.75 0 0 0 .75-.75 2.25 2.25 0 0 0-.1-.664m-5.8 0A2.251 2.251 0 0 1 13.5 2.25H15c1.012 0 1.867.668 2.15 1.586m-5.8 0c-.376.023-.75.05-1.124.08C9.095 4.01 8.25 4.973 8.25 6.108V8.25m0 0H4.875c-.621 0-1.125.504-1.125 1.125v11.25c0 .621.504 1.125 1.125 1.125h9.75c.621 0 1.125-.504 1.125-1.125V9.375c0-.621-.504-1.125-1.125-1.125H8.25ZM6.75 12h.008v.008H6.75V12Zm0 3h.008v.008H6.75V15Zm0 3h.008v.008H6.75V18Z"/>
            </svg>
          </div>
          <div>
            <h3 class="text-2xl font-bold text-neutral-900 dark:text-white mb-3">Task Management</h3>
            <p class="text-neutral-600 dark:text-neutral-400 leading-relaxed">Organize projects with intuitive boards, smart prioritization, and automated workflows that adapt to your team's needs.</p>
          </div>
          <div class="flex items-center gap-4 mt-auto pt-4">
            <span class="text-3xl font-bold text-orange-600 dark:text-orange-400">2.5x</span>
            <span class="text-sm text-neutral-600 dark:text-neutral-400">faster project delivery</span>
          </div>
        </div>

        <!-- Right Column - Stacked Cards -->
        <div class="lg:col-span-7 flex flex-col gap-6">
          <!-- Top Row -->
          <div class="grid sm:grid-cols-2 gap-6">
            <div data-motion="card" class="p-6 bg-neutral-50 dark:bg-neutral-900 rounded-2xl flex flex-col gap-4">
              <div data-motion="icon" class="w-12 h-12 bg-orange-100 dark:bg-orange-900/40 rounded-xl flex items-center justify-center">
                <svg class="w-6 h-6 text-orange-600 dark:text-orange-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M12 6v6h4.5m4.5 0a9 9 0 1 1-18 0 9 9 0 0 1 18 0Z"/>
                </svg>
              </div>
              <h3 class="text-lg font-semibold text-neutral-900 dark:text-white">Time Tracking</h3>
              <p class="text-sm text-neutral-600 dark:text-neutral-400">Automatic time logs with detailed reports and insights.</p>
            </div>

            <div data-motion="card" class="p-6 bg-neutral-50 dark:bg-neutral-900 rounded-2xl flex flex-col gap-4">
              <div data-motion="icon" class="w-12 h-12 bg-orange-100 dark:bg-orange-900/40 rounded-xl flex items-center justify-center">
                <svg class="w-6 h-6 text-orange-600 dark:text-orange-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M18 18.72a9.094 9.094 0 0 0 3.741-.479 3 3 0 0 0-4.682-2.72m.94 3.198.001.031c0 .225-.012.447-.037.666A11.944 11.944 0 0 1 12 21c-2.17 0-4.207-.576-5.963-1.584A6.062 6.062 0 0 1 6 18.719m12 0a5.971 5.971 0 0 0-.941-3.197m0 0A5.995 5.995 0 0 0 12 12.75a5.995 5.995 0 0 0-5.058 2.772m0 0a3 3 0 0 0-4.681 2.72 8.986 8.986 0 0 0 3.74.477m.94-3.197a5.971 5.971 0 0 0-.94 3.197M15 6.75a3 3 0 1 1-6 0 3 3 0 0 1 6 0Zm6 3a2.25 2.25 0 1 1-4.5 0 2.25 2.25 0 0 1 4.5 0Zm-13.5 0a2.25 2.25 0 1 1-4.5 0 2.25 2.25 0 0 1 4.5 0Z"/>
                </svg>
              </div>
              <h3 class="text-lg font-semibold text-neutral-900 dark:text-white">Team Sync</h3>
              <p class="text-sm text-neutral-600 dark:text-neutral-400">Real-time collaboration with instant updates.</p>
            </div>
          </div>

          <!-- Bottom Wide Card -->
          <div data-motion="card" class="p-6 bg-neutral-50 dark:bg-neutral-900 rounded-2xl flex flex-col sm:flex-row gap-6 items-start">
            <div data-motion="icon" class="w-12 h-12 bg-orange-100 dark:bg-orange-900/40 rounded-xl flex items-center justify-center shrink-0">
              <svg class="w-6 h-6 text-orange-600 dark:text-orange-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M3 13.125C3 12.504 3.504 12 4.125 12h2.25c.621 0 1.125.504 1.125 1.125v6.75C7.5 20.496 6.996 21 6.375 21h-2.25A1.125 1.125 0 0 1 3 19.875v-6.75ZM9.75 8.625c0-.621.504-1.125 1.125-1.125h2.25c.621 0 1.125.504 1.125 1.125v11.25c0 .621-.504 1.125-1.125 1.125h-2.25a1.125 1.125 0 0 1-1.125-1.125V8.625ZM16.5 4.125c0-.621.504-1.125 1.125-1.125h2.25C20.496 3 21 3.504 21 4.125v15.75c0 .621-.504 1.125-1.125 1.125h-2.25a1.125 1.125 0 0 1-1.125-1.125V4.125Z"/>
              </svg>
            </div>
            <div class="flex-1">
              <h3 class="text-lg font-semibold text-neutral-900 dark:text-white mb-2">Analytics Dashboard</h3>
              <p class="text-sm text-neutral-600 dark:text-neutral-400">Visual dashboards to track progress, measure outcomes, and make data-driven decisions for your team.</p>
            </div>
            <a href="#" class="text-orange-600 dark:text-orange-400 font-medium text-sm hover:underline whitespace-nowrap">Learn more →</a>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>
<section id="_gallery_masonry_grid_v6_001" class="py-20 sm:py-24 bg-neutral-50 dark:bg-neutral-900">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <!-- Header -->
    <div class="flex flex-col lg:flex-row lg:items-end justify-between gap-8 pb-16">
      <div data-motion="header" class="max-w-xl">
        <span data-motion="badge" class="inline-flex items-center gap-2 px-4 py-1.5 bg-orange-100 dark:bg-orange-900/40 rounded-full text-orange-600 dark:text-orange-400 text-sm font-medium mb-4">
          <span class="w-1.5 h-1.5 bg-orange-500 rounded-full"></span>
          Gallery
        </span>
        <h2 class="text-4xl sm:text-5xl font-bold text-neutral-900 dark:text-white">
          <span data-animate="heading">Moments Captured</span>
        </h2>
        <p data-animate="text" class="text-lg text-neutral-600 dark:text-neutral-400 mt-4">A collection of extraordinary moments frozen in time, each telling its own unique story.</p>
      </div>
      <a data-motion="link" href="#" class="inline-flex items-center gap-2 text-orange-600 dark:text-orange-400 font-semibold hover:gap-3 transition-all w-fit">
        View Full Gallery
        <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3"/>
        </svg>
      </a>
    </div>

    <!-- Masonry Grid -->
    <div class="grid md:grid-cols-12 gap-5">
      <!-- Large Featured Image -->
      <div data-motion="image" class="md:col-span-7 md:row-span-2 group">
        <div class="relative h-full min-h-[400px] md:min-h-[600px] rounded-3xl overflow-hidden">
          <img data-motion="image" src="https://images.unsplash.com/photo-1682687220742-aba13b6e50ba?w=1200&auto=format&fit=crop&q=80" alt="Mountain landscape" class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-700">
          <div class="absolute inset-0 bg-linear-to-t from-neutral-900/60 via-transparent to-transparent"></div>
          <div class="absolute bottom-0 left-0 right-0 p-8">
            <span data-motion="badge" class="inline-block px-3 py-1 bg-orange-500 text-white text-xs font-medium rounded-full mb-3">Featured</span>
            <h3 class="text-2xl font-bold text-white">Alpine Wilderness</h3>
            <p class="text-neutral-300 mt-1">Dolomites, Italy</p>
          </div>
        </div>
      </div>

      <!-- Top Right Image -->
      <div data-motion="image" class="md:col-span-5 group">
        <div class="relative h-64 md:h-[290px] rounded-3xl overflow-hidden">
          <img data-motion="image" src="https://images.unsplash.com/photo-1501785888041-af3ef285b470?w=800&auto=format&fit=crop&q=80" alt="Lake reflection" class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-700">
          <div class="absolute inset-0 bg-linear-to-t from-neutral-900/60 via-transparent to-transparent opacity-0 group-hover:opacity-100 transition-opacity duration-300"></div>
          <div class="absolute bottom-0 left-0 right-0 p-6 opacity-0 group-hover:opacity-100 transition-opacity duration-300">
            <h3 class="text-lg font-semibold text-white">Mirror Lake</h3>
            <p class="text-neutral-300 text-sm">New Zealand</p>
          </div>
        </div>
      </div>

      <!-- Bottom Right Image -->
      <div data-motion="image" class="md:col-span-5 group">
        <div class="relative h-64 md:h-[290px] rounded-3xl overflow-hidden">
          <img data-motion="image" src="https://images.unsplash.com/photo-1470071459604-3b5ec3a7fe05?w=800&auto=format&fit=crop&q=80" alt="Foggy forest" class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-700">
          <div class="absolute inset-0 bg-linear-to-t from-neutral-900/60 via-transparent to-transparent opacity-0 group-hover:opacity-100 transition-opacity duration-300"></div>
          <div class="absolute bottom-0 left-0 right-0 p-6 opacity-0 group-hover:opacity-100 transition-opacity duration-300">
            <h3 class="text-lg font-semibold text-white">Misty Forest</h3>
            <p class="text-neutral-300 text-sm">Pacific Northwest</p>
          </div>
        </div>
      </div>

      <!-- Bottom Row - 3 Images -->
      <div data-motion="image" class="md:col-span-4 group">
        <div class="relative h-64 rounded-3xl overflow-hidden">
          <img data-motion="image" src="https://images.unsplash.com/photo-1433086966358-54859d0ed716?w=600&auto=format&fit=crop&q=80" alt="Waterfall" class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-700">
          <div class="absolute inset-0 bg-linear-to-t from-neutral-900/60 via-transparent to-transparent opacity-0 group-hover:opacity-100 transition-opacity duration-300"></div>
          <div class="absolute bottom-0 left-0 right-0 p-5 opacity-0 group-hover:opacity-100 transition-opacity duration-300">
            <h3 class="text-base font-semibold text-white">Hidden Falls</h3>
          </div>
        </div>
      </div>

      <div data-motion="image" class="md:col-span-4 group">
        <div class="relative h-64 rounded-3xl overflow-hidden">
          <img data-motion="image" src="https://images.unsplash.com/photo-1505765050516-f72dcac9c60e?w=600&auto=format&fit=crop&q=80" alt="Autumn forest" class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-700">
          <div class="absolute inset-0 bg-linear-to-t from-neutral-900/60 via-transparent to-transparent opacity-0 group-hover:opacity-100 transition-opacity duration-300"></div>
          <div class="absolute bottom-0 left-0 right-0 p-5 opacity-0 group-hover:opacity-100 transition-opacity duration-300">
            <h3 class="text-base font-semibold text-white">Autumn Colors</h3>
          </div>
        </div>
      </div>

      <div data-motion="image" class="md:col-span-4 group">
        <div class="relative h-64 rounded-3xl overflow-hidden">
          <img data-motion="image" src="https://images.unsplash.com/photo-1464822759023-fed622ff2c3b?w=600&auto=format&fit=crop&q=80" alt="Mountain peak" class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-700">
          <div class="absolute inset-0 bg-linear-to-t from-neutral-900/60 via-transparent to-transparent opacity-0 group-hover:opacity-100 transition-opacity duration-300"></div>
          <div class="absolute bottom-0 left-0 right-0 p-5 opacity-0 group-hover:opacity-100 transition-opacity duration-300">
            <h3 class="text-base font-semibold text-white">Summit View</h3>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>
<section id="_about_bento_cards_v6_001" class="py-20 sm:py-24 bg-white dark:bg-neutral-950">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">

    <!-- Magazine-style Header -->
    <div class="grid lg:grid-cols-12 gap-8 lg:gap-12 items-end mb-16">
      <div class="lg:col-span-7">
        <span data-motion="badge" class="text-orange-600 dark:text-orange-400 text-sm font-semibold tracking-wide uppercase block mb-4">About Us</span>
        <h2 class="text-neutral-900 dark:text-white text-4xl sm:text-5xl lg:text-6xl font-bold leading-[1.1]">
          <span data-animate="heading">Building Digital Excellence</span>
        </h2>
      </div>
      <div class="lg:col-span-5">
        <p class="text-neutral-600 dark:text-neutral-400 text-lg leading-relaxed" data-animate="text">
          We craft digital experiences that transform businesses. Our approach combines strategic thinking with creative execution.
        </p>
      </div>
    </div>

    <!-- Main Content Grid -->
    <div class="grid lg:grid-cols-3 gap-6">

      <!-- Large Image with Floating Card -->
