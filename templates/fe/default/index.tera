        <img data-motion="image"
          src="https://images.unsplash.com/photo-1522071820081-009f0129c71c?w=1200&auto=format&fit=crop&q=80"
          alt="Team collaboration"
          class="w-full h-full object-cover"
        >
        <div class="absolute bottom-6 left-6 right-6 p-6 bg-white/95 dark:bg-neutral-900/95 backdrop-blur-xs rounded-2xl">
          <div class="flex items-center justify-between">
            <div>
              <span class="text-orange-600 dark:text-orange-400 text-3xl font-bold block">Since 2015</span>
              <span class="text-neutral-500 dark:text-neutral-400 text-sm">Crafting excellence</span>
            </div>
            <a data-motion="button" href="#" class="inline-flex items-center gap-2 text-orange-600 dark:text-orange-400 font-semibold hover:gap-3 transition-all duration-300">
              Our Story
              <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3"/>
              </svg>
            </a>
          </div>
        </div>
      </div>

      <!-- Stats Column -->
      <div class="flex flex-col gap-6">
        <div data-motion="card" class="p-6 border-orange-500 bg-neutral-50 dark:bg-neutral-900 rounded-r-2xl">
          <span class="text-orange-600 dark:text-orange-400 text-4xl font-bold block">250+</span>
          <span class="text-neutral-600 dark:text-neutral-400 text-base">Projects Delivered</span>
        </div>
        <div data-motion="card" class="p-6 border-orange-500 bg-neutral-50 dark:bg-neutral-900 rounded-r-2xl">
          <span class="text-orange-600 dark:text-orange-400 text-4xl font-bold block">98%</span>
          <span class="text-neutral-600 dark:text-neutral-400 text-base">Client Satisfaction</span>
        </div>
        <div data-motion="card" class="p-6 border-orange-500 bg-neutral-50 dark:bg-neutral-900 rounded-r-2xl">
          <span class="text-orange-600 dark:text-orange-400 text-4xl font-bold block">45+</span>
          <span class="text-neutral-600 dark:text-neutral-400 text-base">Team Members</span>
        </div>
        <div data-motion="card" class="flex-1 p-6 bg-orange-50 dark:bg-orange-900/20 rounded-2xl flex flex-col justify-center">
          <h3 class="text-neutral-900 dark:text-white text-xl font-bold mb-2">Our Mission</h3>
          <p class="text-neutral-600 dark:text-neutral-400 text-sm">Empowering businesses through innovative digital solutions.</p>
        </div>
      </div>
    </div>

    <!-- Bottom Divider -->
    <div class="w-full h-px bg-neutral-200 dark:bg-neutral-800 mt-16"></div>
  </div>
</section>
<section id="_testimonial_bento_video_cards_t15_001" class="py-20 sm:py-24 bg-white dark:bg-neutral-950">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">

    <!-- Header -->
    <div class="flex flex-col lg:flex-row lg:items-end lg:justify-between gap-6 mb-12">
      <div>
        <span data-motion="badge" class="text-orange-600 dark:text-orange-400 text-sm font-semibold tracking-wide uppercase mb-3 block">Video Stories</span>
        <h2 class="text-3xl sm:text-4xl font-bold text-neutral-900 dark:text-white">
          <span data-animate="heading">Watch their success stories</span>
        </h2>
      </div>
      <p class="text-neutral-600 dark:text-neutral-400 max-w-md lg:text-right" data-animate="text">
        Hear directly from leaders who transformed their organizations with our platform.
      </p>
    </div>

    <!-- Bento Grid -->
    <div class="grid lg:grid-cols-3 gap-5">

      <!-- Large Featured Card -->
      <div class="lg:col-span-2 lg:row-span-2">
        <div data-motion="card" class="group relative h-full min-h-[400px] lg:min-h-[500px] rounded-3xl overflow-hidden">
          <img data-motion="image"
            src="https://images.unsplash.com/photo-1560250097-0b93528c311a?w=900&auto=format&fit=crop&q=80"
            alt="James Wilson"
            class="absolute inset-0 w-full h-full object-cover transition-transform duration-700 group-hover:scale-105"
          >
          <div class="absolute inset-0 bg-linear-to-t from-neutral-900/90 via-neutral-900/40 to-transparent"></div>
          <div class="absolute inset-0 flex flex-col justify-between p-6 sm:p-8">
            <!-- Play Button -->
            <div class="flex justify-end">
              <button data-motion="button" type="button" class="w-14 h-14 rounded-full bg-orange-500 flex items-center justify-center hover:bg-orange-600 transition-colors group/btn" aria-label="Play video">
                <svg class="w-6 h-6 text-white ml-1" fill="currentColor" viewBox="0 0 24 24">
                  <path d="M8 5v14l11-7z"/>
                </svg>
              </button>
            </div>
            <!-- Content -->
            <div>
              <p class="text-white text-lg sm:text-xl font-medium leading-relaxed mb-6 max-w-lg">
                "This platform revolutionized how we approach product development. The collaboration features alone saved us countless hours."
              </p>
              <div class="flex items-center gap-4">
                <div class="w-12 h-12 rounded-full bg-orange-500 flex items-center justify-center text-white font-bold">JW</div>
                <div>
                  <h4 class="text-white font-semibold">James Wilson</h4>
                  <p class="text-orange-300 text-sm">CTO, TechFlow Inc</p>
                </div>
              </div>
            </div>
          </div>
        </div>
      </div>

      <!-- Small Card 1 -->
      <div data-motion="card" class="group relative min-h-[240px] rounded-3xl overflow-hidden">
        <img data-motion="image"
          src="https://images.unsplash.com/photo-1573496359142-b8d87734a5a2?w=600&auto=format&fit=crop&q=80"
          alt="Elena Rodriguez"
          class="absolute inset-0 w-full h-full object-cover transition-transform duration-700 group-hover:scale-105"
        >
        <div class="absolute inset-0 bg-linear-to-t from-neutral-900/90 via-neutral-900/30 to-transparent"></div>
        <div class="absolute inset-0 flex flex-col justify-between p-5">
          <div class="flex justify-end">
            <button type="button" class="w-10 h-10 rounded-full bg-white/20 backdrop-blur-xs flex items-center justify-center hover:bg-white/30 transition-colors" aria-label="Play video">
              <svg class="w-4 h-4 text-white ml-0.5" fill="currentColor" viewBox="0 0 24 24">
                <path d="M8 5v14l11-7z"/>
              </svg>
            </button>
          </div>
          <div>
            <h4 class="text-white font-semibold">Elena Rodriguez</h4>
            <p class="text-neutral-300 text-sm">VP Operations, Nexus</p>
          </div>
        </div>
      </div>

      <!-- Small Card 2 -->
      <div data-motion="card" class="group relative min-h-[240px] rounded-3xl overflow-hidden">
        <img data-motion="image"
          src="https://images.unsplash.com/photo-1507003211169-0a1dd7228f2d?w=600&auto=format&fit=crop&q=80"
          alt="Michael Chang"
          class="absolute inset-0 w-full h-full object-cover transition-transform duration-700 group-hover:scale-105"
        >
        <div class="absolute inset-0 bg-linear-to-t from-neutral-900/90 via-neutral-900/30 to-transparent"></div>
        <div class="absolute inset-0 flex flex-col justify-between p-5">
          <div class="flex justify-end">
            <button type="button" class="w-10 h-10 rounded-full bg-white/20 backdrop-blur-xs flex items-center justify-center hover:bg-white/30 transition-colors" aria-label="Play video">
              <svg class="w-4 h-4 text-white ml-0.5" fill="currentColor" viewBox="0 0 24 24">
                <path d="M8 5v14l11-7z"/>
              </svg>
            </button>
          </div>
          <div>
            <h4 class="text-white font-semibold">Michael Chang</h4>
            <p class="text-neutral-300 text-sm">Director, Scale Ventures</p>
          </div>
        </div>
      </div>

    </div>

    <!-- Stats Row -->
    <div data-motion="stats" class="grid grid-cols-3 gap-8 mt-12 pt-12 border-t border-neutral-200 dark:border-neutral-800">
      <div class="text-center">
        <span class="text-3xl sm:text-4xl font-bold text-neutral-900 dark:text-white block">50+</span>
        <span class="text-sm text-neutral-500 dark:text-neutral-400">Video Stories</span>
      </div>
      <div class="text-center">
        <span class="text-3xl sm:text-4xl font-bold text-neutral-900 dark:text-white block">4.9</span>
        <span class="text-sm text-neutral-500 dark:text-neutral-400">Average Rating</span>
      </div>
      <div class="text-center">
        <span class="text-3xl sm:text-4xl font-bold text-neutral-900 dark:text-white block">98%</span>
        <span class="text-sm text-neutral-500 dark:text-neutral-400">Would Recommend</span>
      </div>
    </div>

  </div>
</section>
