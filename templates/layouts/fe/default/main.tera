<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>{{ landing.app_name }}</title>

  {% if setting.icon %}<link rel="icon" href="{{ get_file(path=setting.icon) | safe }}">{% endif %}

  <!-- Fonts -->
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800;900&display=swap" rel="stylesheet">

  <!-- Tailwind CSS (CDN v4 browser — sama dgn NodeAdmin fe/default) -->
  <script src="https://cdn.jsdelivr.net/npm/@tailwindcss/browser@4"></script>

  <!-- Motion.js for animations (CDN) -->
  <script src="https://cdn.jsdelivr.net/npm/motion@latest/dist/motion.js"></script>

  <!-- Style kustom (diekstrak dari template monolitik) -->
  <link rel="stylesheet" href="/static/fe/default/css/style.css">
</head>
<body class="bg-white dark:bg-neutral-950">
<div class="page-wraper">
<header id="_header_notification_bell_h13_001" class="relative bg-white/95 dark:bg-neutral-950/95 backdrop-blur-xl border-b border-neutral-100 dark:border-neutral-900">
 <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
 <div class="flex items-center justify-between h-16">
 <!-- Logo — bind ke landing (logo + name). Fallback ikon bawaan bila kosong. -->
 <a data-motion="logo" href="/" class="flex items-center gap-2.5">
 {% if landing.logo %}
 <img src="{{ get_file(path=landing.logo) | safe }}" alt="{{ landing.app_name }}" class="w-10 h-10 rounded-xl object-contain bg-white">
 {% else %}
 <div data-motion="icon" class="w-10 h-10 bg-linear-to-br from-orange-500 to-orange-600 rounded-xl flex items-center justify-center">
 <svg class="w-5 h-5 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
 <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 17h5l-1.405-1.405A2.032 2.032 0 0118 14.158V11a6.002 6.002 0 00-4-5.659V5a2 2 0 10-4 0v.341C7.67 6.165 6 8.388 6 11v3.159c0 .538-.214 1.055-.595 1.436L4 17h5m6 0v1a3 3 0 11-6 0v-1m6 0H9"/>
 </svg>
 </div>
 {% endif %}
 <span class="text-xl font-bold text-neutral-900 dark:text-white">{{ landing.app_name }}</span>
 </a>

 <!-- Navigation -->
 <nav data-motion="nav" class="hidden lg:flex items-center gap-8">
 <a href="#" class="text-sm font-medium text-neutral-900 dark:text-white hover:text-orange-500 dark:hover:text-orange-400 transition-colors">Dashboard</a>
 <a href="#" class="text-sm font-medium text-neutral-600 dark:text-neutral-400 hover:text-orange-500 dark:hover:text-orange-400 transition-colors">Messages</a>
 <a href="#" class="text-sm font-medium text-neutral-600 dark:text-neutral-400 hover:text-orange-500 dark:hover:text-orange-400 transition-colors">Calendar</a>
 <a href="#" class="text-sm font-medium text-neutral-600 dark:text-neutral-400 hover:text-orange-500 dark:hover:text-orange-400 transition-colors">Settings</a>
 </nav>

 <!-- Right Actions -->
 <div data-motion="actions" class="flex items-center gap-2">
 <button data-motion="button"
 onclick="document.documentElement.classList.toggle('dark')"
 class="w-10 h-10 flex items-center justify-center rounded-xl hover:bg-neutral-100 dark:hover:bg-neutral-800 transition-colors"
 >
 <svg class="w-5 h-5 text-neutral-600 dark:text-neutral-400 hidden dark:block" fill="none" stroke="currentColor" viewBox="0 0 24 24">
 <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 3v1m0 16v1m9-9h-1M4 12H3m15.364 6.364l-.707-.707M6.343 6.343l-.707-.707m12.728 0l-.707.707M6.343 17.657l-.707.707M16 12a4 4 0 11-8 0 4 4 0 018 0z"/>
 </svg>
 <svg class="w-5 h-5 text-neutral-600 dark:text-neutral-400 block dark:hidden" fill="none" stroke="currentColor" viewBox="0 0 24 24">
 <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M20.354 15.354A9 9 0 018.646 3.646 9.003 9.003 0 0012 21a9.003 9.003 0 008.354-5.646z"/>
 </svg>
 </button>

 <!-- Notification Bell with Dropdown -->
 <div class="relative">
 <button data-motion="button"
 onclick="document.getElementById('notificationDropdown').classList.toggle('active')"
 class="w-10 h-10 flex items-center justify-center rounded-xl hover:bg-neutral-100 dark:hover:bg-neutral-800 transition-colors relative"
 >
 <svg class="w-5 h-5 text-neutral-600 dark:text-neutral-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
 <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 17h5l-1.405-1.405A2.032 2.032 0 0118 14.158V11a6.002 6.002 0 00-4-5.659V5a2 2 0 10-4 0v.341C7.67 6.165 6 8.388 6 11v3.159c0 .538-.214 1.055-.595 1.436L4 17h5m6 0v1a3 3 0 11-6 0v-1m6 0H9"/>
 </svg>
 <span class="absolute top-1.5 right-1.5 w-5 h-5 bg-orange-500 text-white text-[10px] font-bold rounded-full flex items-center justify-center animate-pulse">5</span>
 </button>

 <!-- Notification Dropdown -->
 <div id="notificationDropdown" class="notification-dropdown absolute top-full right-0 mt-2 w-80 bg-white dark:bg-neutral-900 rounded-2xl shadow-2xl border border-neutral-100 dark:border-neutral-800 overflow-hidden">
 <div class="p-4 border-b border-neutral-100 dark:border-neutral-800 flex items-center justify-between">
 <h3 class="font-semibold text-neutral-900 dark:text-white">Notifications</h3>
 <a href="#" class="text-xs text-orange-500 hover:text-orange-600 font-medium">Mark all read</a>
 </div>
 <div class="max-h-80 overflow-y-auto">
 <a href="#" class="flex items-start gap-3 p-4 hover:bg-neutral-50 dark:hover:bg-neutral-800 transition-colors border-orange-500">
 <div data-motion="icon" class="w-10 h-10 bg-orange-100 dark:bg-orange-900/30 rounded-full flex items-center justify-center shrink-0">
 <svg class="w-5 h-5 text-orange-500" fill="none" stroke="currentColor" viewBox="0 0 24 24">
 <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4m0 4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/>
 </svg>
 </div>
 <div class="flex-1 min-w-0">
 <p class="text-sm font-medium text-neutral-900 dark:text-white">New message received</p>
 <p class="text-xs text-neutral-500 mt-0.5">Sarah sent you a message</p>
 <p class="text-xs text-orange-500 mt-1">2 min ago</p>
 </div>
 </a>
 <a href="#" class="flex items-start gap-3 p-4 hover:bg-neutral-50 dark:hover:bg-neutral-800 transition-colors">
 <div data-motion="icon" class="w-10 h-10 bg-orange-100 dark:bg-orange-900/30 rounded-full flex items-center justify-center shrink-0">
 <svg class="w-5 h-5 text-orange-500" fill="none" stroke="currentColor" viewBox="0 0 24 24">
 <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"/>
 </svg>
 </div>
 <div class="flex-1 min-w-0">
 <p class="text-sm font-medium text-neutral-900 dark:text-white">Task completed</p>
 <p class="text-xs text-neutral-500 mt-0.5">Project milestone achieved</p>
 <p class="text-xs text-neutral-400 mt-1">1 hour ago</p>
 </div>
 </a>
 <a href="#" class="flex items-start gap-3 p-4 hover:bg-neutral-50 dark:hover:bg-neutral-800 transition-colors">
 <div data-motion="icon" class="w-10 h-10 bg-orange-100 dark:bg-orange-900/30 rounded-full flex items-center justify-center shrink-0">
 <svg class="w-5 h-5 text-orange-500" fill="none" stroke="currentColor" viewBox="0 0 24 24">
 <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0zm6 3a2 2 0 11-4 0 2 2 0 014 0zM7 10a2 2 0 11-4 0 2 2 0 014 0z"/>
 </svg>
 </div>
 <div class="flex-1 min-w-0">
 <p class="text-sm font-medium text-neutral-900 dark:text-white">New team member</p>
 <p class="text-xs text-neutral-500 mt-0.5">Alex joined the team</p>
 <p class="text-xs text-neutral-400 mt-1">3 hours ago</p>
 </div>
 </a>
 </div>
 <div class="p-3 border-t border-neutral-100 dark:border-neutral-800">
 <a href="#" class="block text-center text-sm text-orange-500 hover:text-orange-600 font-medium">View all notifications</a>
 </div>
 </div>
 </div>

 <!-- Profile -->
 <button class="w-10 h-10 rounded-xl overflow-hidden ring-2 ring-transparent hover:ring-orange-500 transition-all">
 <img data-motion="image" src="https://images.unsplash.com/photo-1494790108377-be9c29b29330?w=100&h=100&fit=crop&crop=face" alt="Profile" class="w-full h-full object-cover">
 </button>
 </div>
 </div>
 </div>
</header>

{% block content %}{% endblock content %}

<footer id="_footer_dark_subscribe_v6_001" class="bg-white dark:bg-neutral-950">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">

    <!-- Newsletter Banner -->
    <div data-motion="newsletter" class="py-12 border-b border-neutral-200 dark:border-neutral-800">
      <div class="flex flex-col lg:flex-row items-center justify-between gap-8">
        <div class="text-center lg:text-left">
          <h3 class="text-neutral-900 dark:text-white text-2xl lg:text-3xl font-bold mb-2">Join our community</h3>
          <p class="text-neutral-600 dark:text-neutral-400">Get early access to new features and exclusive content.</p>
        </div>
        <form class="flex w-full max-w-md">
          <input data-motion="input" type="email" placeholder="Enter your email" class="flex-1 px-5 py-3.5 bg-white dark:bg-neutral-900 border border-neutral-200 dark:border-neutral-800 rounded-l-xl text-neutral-900 dark:text-white placeholder-neutral-500 focus:outline-hidden focus:border-orange-500 transition-colors">
          <button data-motion="button" type="submit" class="px-6 py-3.5 bg-orange-500 hover:bg-orange-600 transition-colors rounded-r-xl text-neutral-900 dark:text-white font-semibold whitespace-nowrap">
            Subscribe
          </button>
        </form>
      </div>
    </div>

    <!-- Main Links Grid -->
    <div class="py-16 grid sm:grid-cols-2 lg:grid-cols-5 gap-10">

      <!-- Brand Column — bind ke landing (logo, name, description, kontak). -->
      <div data-motion="brand" class="lg:col-span-1">
        <a href="/" class="flex items-center gap-3 mb-6">
          {% if landing.logo %}
          <img src="{{ get_file(path=landing.logo) | safe }}" alt="{{ landing.app_name }}" class="w-10 h-10 rounded-xl object-contain bg-white">
          {% else %}
          <div data-motion="icon" class="w-10 h-10 bg-linear-to-br from-orange-400 to-orange-500 rounded-xl flex items-center justify-center">
            <svg class="w-6 h-6 text-neutral-900 dark:text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 15a4 4 0 004 4h9a5 5 0 10-.1-9.999 5.002 5.002 0 10-9.78 2.096A4.001 4.001 0 003 15z"/>
            </svg>
          </div>
          {% endif %}
          <span class="text-xl font-bold text-neutral-900 dark:text-white">{{ landing.app_name }}</span>
        </a>
        {% if landing.description %}
        <p class="text-neutral-600 dark:text-neutral-400 text-sm">{{ landing.description | safe }}</p>
        {% else %}
        <p class="text-neutral-600 dark:text-neutral-400 text-sm">Secure cloud storage for modern teams.</p>
        {% endif %}
        <ul class="mt-5 space-y-2 text-sm">
          {% if landing.email %}
          <li><a href="mailto:{{ landing.email }}" class="text-neutral-600 dark:text-neutral-400 hover:text-orange-600 transition-colors"><i class="fas fa-envelope me-2"></i>{{ landing.email }}</a></li>
          {% endif %}
          {% if landing.phone %}
          <li><a href="tel:{{ landing.phone }}" class="text-neutral-600 dark:text-neutral-400 hover:text-orange-600 transition-colors"><i class="fas fa-phone me-2"></i>{{ landing.phone }}</a></li>
          {% endif %}
          {% if landing.address %}
          <li class="text-neutral-600 dark:text-neutral-400"><i class="fas fa-location-dot me-2"></i>{{ landing.address }}</li>
          {% endif %}
        </ul>
      </div>

      <!-- Links Columns -->
      <div data-motion="column">
        <h4 class="text-neutral-900 dark:text-white font-semibold mb-5">Company</h4>
        <ul class="space-y-3">
          <li><a href="#" class="text-neutral-600 dark:text-neutral-400 hover:text-orange-600 dark:text-orange-400 transition-colors">About</a></li>
          <li><a href="#" class="text-neutral-600 dark:text-neutral-400 hover:text-orange-600 dark:text-orange-400 transition-colors">Pricing</a></li>
          <li><a href="#" class="text-neutral-600 dark:text-neutral-400 hover:text-orange-600 dark:text-orange-400 transition-colors">Features</a></li>
          <li><a href="#" class="text-neutral-600 dark:text-neutral-400 hover:text-orange-600 dark:text-orange-400 transition-colors">Enterprise</a></li>
        </ul>
      </div>

      <div data-motion="column">
        <h4 class="text-neutral-900 dark:text-white font-semibold mb-5">Products</h4>
        <ul class="space-y-3">
          <li><a href="#" class="text-neutral-600 dark:text-neutral-400 hover:text-orange-600 dark:text-orange-400 transition-colors">Cloud Storage</a></li>
          <li><a href="#" class="text-neutral-600 dark:text-neutral-400 hover:text-orange-600 dark:text-orange-400 transition-colors">Team Sync</a></li>
          <li><a href="#" class="text-neutral-600 dark:text-neutral-400 hover:text-orange-600 dark:text-orange-400 transition-colors">File Sharing</a></li>
          <li><a href="#" class="text-neutral-600 dark:text-neutral-400 hover:text-orange-600 dark:text-orange-400 transition-colors">API Access</a></li>
        </ul>
      </div>

      <div data-motion="column">
        <h4 class="text-neutral-900 dark:text-white font-semibold mb-5">Resources</h4>
        <ul class="space-y-3">
          <li><a href="#" class="text-neutral-600 dark:text-neutral-400 hover:text-orange-600 dark:text-orange-400 transition-colors">Documentation</a></li>
          <li><a href="#" class="text-neutral-600 dark:text-neutral-400 hover:text-orange-600 dark:text-orange-400 transition-colors">Tutorials</a></li>
          <li><a href="#" class="text-neutral-600 dark:text-neutral-400 hover:text-orange-600 dark:text-orange-400 transition-colors">Blog</a></li>
          <li><a href="#" class="text-neutral-600 dark:text-neutral-400 hover:text-orange-600 dark:text-orange-400 transition-colors">Changelog</a></li>
        </ul>
      </div>

      <div data-motion="column">
        <h4 class="text-neutral-900 dark:text-white font-semibold mb-5">Legal</h4>
        <ul class="space-y-3">
          <li><a href="#" class="text-neutral-600 dark:text-neutral-400 hover:text-orange-600 dark:text-orange-400 transition-colors">Privacy</a></li>
          <li><a href="#" class="text-neutral-600 dark:text-neutral-400 hover:text-orange-600 dark:text-orange-400 transition-colors">Terms</a></li>
          <li><a href="#" class="text-neutral-600 dark:text-neutral-400 hover:text-orange-600 dark:text-orange-400 transition-colors">Cookies</a></li>
          <li><a href="#" class="text-neutral-600 dark:text-neutral-400 hover:text-orange-600 dark:text-orange-400 transition-colors">GDPR</a></li>
        </ul>
      </div>

    </div>

    <!-- Bottom Bar -->
    <div data-motion="bottom" class="py-8 border-t border-neutral-200 dark:border-neutral-800 flex flex-col sm:flex-row items-center justify-between gap-6">
      <p class="text-neutral-500 text-sm">{{ landing.copyright }}</p>
      <div class="flex items-center gap-4">
        <a href="#" class="text-neutral-600 dark:text-neutral-400 hover:text-orange-600 dark:text-orange-400 transition-colors" aria-label="Twitter">
          <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24">
            <path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z"/>
          </svg>
        </a>
        <a href="#" class="text-neutral-600 dark:text-neutral-400 hover:text-orange-600 dark:text-orange-400 transition-colors" aria-label="GitHub">
          <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24">
            <path d="M12 0c-6.626 0-12 5.373-12 12 0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23.957-.266 1.983-.399 3.003-.404 1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576 4.765-1.589 8.199-6.086 8.199-11.386 0-6.627-5.373-12-12-12z"/>
          </svg>
        </a>
        <a href="#" class="text-neutral-600 dark:text-neutral-400 hover:text-orange-600 dark:text-orange-400 transition-colors" aria-label="LinkedIn">
          <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24">
            <path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433c-1.144 0-2.063-.926-2.063-2.065 0-1.138.92-2.063 2.063-2.063 1.14 0 2.064.925 2.064 2.063 0 1.139-.925 2.065-2.064 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/>
          </svg>
        </a>
      </div>
    </div>

  </div>
</footer>

<!-- Animasi motion (diekstrak ke file) -->
<script src="/static/fe/default/js/motion.js"></script>
</div><!-- /page-wraper -->
</body>
</html>
