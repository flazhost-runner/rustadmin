<!DOCTYPE html>
<html lang="en" class="scroll-smooth">
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <meta name="color-scheme" content="light">
  <title>{% if setting.name %}{{ setting.name }}{% else %}RustAdmin{% endif %}</title>
  {% if setting.icon %}<link rel="icon" href="{{ get_file(path=setting.icon) | safe }}">{% endif %}
  <script src="https://cdn.tailwindcss.com"></script>
  <link rel="stylesheet" href="/static/be/default/vendor/fontawesome-free/css/all.min.css">
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;600;800&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="/static/fe/default/css/style.css">
</head>
<body class="font-[Inter] text-slate-800 bg-white">
  <header class="fixed top-0 inset-x-0 z-40 backdrop-blur bg-white/80 border-b">
    <div class="max-w-6xl mx-auto px-6 py-4 flex items-center justify-between">
      <a href="/" class="flex items-center gap-2 font-extrabold text-xl text-indigo-600">
        {% if setting.logo %}<img src="{{ get_file(path=setting.logo) | safe }}" alt="logo" style="height:32px">{% else %}<i class="fas fa-chart-line"></i>{% endif %}
        <span>{% if setting.name %}{{ setting.name }}{% else %}RustAdmin{% endif %}</span>
      </a>
      <nav class="hidden md:flex gap-8 text-sm text-slate-600">
        <a href="#services" class="hover:text-indigo-600">Services</a>
        <a href="#features" class="hover:text-indigo-600">Features</a>
        <a href="#about" class="hover:text-indigo-600">About</a>
        <a href="#contact" class="hover:text-indigo-600">Contact</a>
      </nav>
      <a href="/auth/login" class="px-5 py-2 rounded-lg bg-indigo-600 text-white text-sm font-medium">Sign in</a>
    </div>
  </header>

  <main class="pt-16">
    {% block content %}{% endblock content %}
  </main>

  <footer class="bg-slate-900 text-slate-300 py-10">
    <div class="max-w-6xl mx-auto px-6 flex flex-col md:flex-row items-center justify-between gap-4">
      <p class="font-bold text-white">{% if setting.name %}{{ setting.name }}{% else %}RustAdmin{% endif %}</p>
      <p class="text-sm">{% if setting.copyright %}{{ setting.copyright }}{% else %}© RustAdmin{% endif %}</p>
    </div>
  </footer>

  <script src="/static/fe/default/js/motion.js"></script>
</body>
</html>
